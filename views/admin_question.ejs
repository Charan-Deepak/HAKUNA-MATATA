                        <input type="text" id="text_question" name="option_array" required>
                        <br>
                        <input type="checkbox" id="option_type_checkbox" name="correct_checkboxes" value="3">
                        <input type="text" id="text_question" name="option_array" required>
                        <br>
                        <input type="checkbox" id="option_type_checkbox" name="correct_checkboxes" value="4">
                        <input type="text" id="text_question" name="option_array" required>
                        <br><br>

                    </div>
                    `;
            } 

            // value=3 
             function text_answer(i){ 
                document.getElementById("your_options"+i).innerHTML = `
                    <div class="text">
                        <br>
