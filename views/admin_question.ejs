        //addinput question
            function addinputquestion(i){ 
             
            //form
            const form=document.createElement("form");
            form.className="form";

            //text
            const label1=document.createElement("label");
            label1.innerHTML="Enter the Question<br><br>";
            label1.htmlFor="text_question";

            //text 
            const text=document.createElement("input");
            text.type="text";
            text.id="text_question";
            text.name="text_question";
            text.required;

            //choose option
            const label123=document.createElement("label");
            label123.innerHTML="choose your options<br>";
            label123.htmlFor="text_question1";

            //select question
            const label2=document.createElement("label");
            label2.innerHTML="Select question type";
            
            //radio
            const radio=document.createElement("input");
            radio.type="radio";
            radio.id="option_type_radio";
            radio.name="option";
            radio.value="1";
            radio.required; 
            const labelradio=document.createElement("label");
            labelradio.innerHTML="Radio";
            // radio.addEventListener("click",radio_answer);
            radio.addEventListener("click", function() {
            radio_answer(i);
            });

            //checkbox
            const checkbox=document.createElement("input");
            checkbox.type="radio";
            checkbox.id="option_type_checkbox";
            checkbox.name="option";
            checkbox.value="2";
            checkbox.required;
            const labelcheckbox=document.createElement("label");
            labelcheckbox.innerHTML="Checkbox";
            // checkbox.addEventListener("click",checkbox_answer);
            checkbox.addEventListener("click", function() {
            checkbox_answer(i);
            });


            //text
            const text1=document.createElement("input");
            text1.type="radio";
            text1.id="option_type_text";
            text1.name="option";
            text1.value="3";
            text1.required;
            const labeltext1=document.createElement("label");
            labeltext1.innerHTML="text";
            // text1.addEventListener("click",text_answer);
            text1.addEventListener("click", function() {
            text_answer(i);
            });


            //delete
            const btn=document.createElement("a");
            btn.className="delete";
            btn.innerHTML="&times";
            btn.type="button";
            btn.addEventListener("click",removeInput);
            

            //div of your option
            const your_options=document.createElement("div");
            your_options.id="your_options"+i;
            your_options.innerHTML="hello";
            
            //childappend
            questionblock.appendChild(form);
            form.appendChild(label1);
            form.appendChild(text);
            form.appendChild(label123);
            form.appendChild(radio);
            form.appendChild(labelradio);
            form.appendChild(checkbox);
            form.appendChild(labelcheckbox);
            form.appendChild(text1);
            form.appendChild(labeltext1);
            form.appendChild(your_options);
            form.appendChild(btn);
            }
            
            // addbtn.addEventListener("click",addinputquestion(i));
            addbtn.addEventListener("click", function() {
            addinputquestion(i);
            i++
            });

        //value=1 
             function radio_answer(i){ 
              
               document.getElementById("your_options"+i).innerHTML = `
                    <div class="radio">
                        <br>
                        <label for="radio">Enter the options</label>
                        <br>
                        <input type="radio" id="option_type_radio" name="correct" value="1" required>
                        <input type="text" id="text_question" name="option_array" required>
                        <br>
                        <input type="radio" id="option_type_radio" name="correct" value="2" required>
                        <input type="text" id="text_question" name="option_array" required>
                        <br>
                        <input type="radio" id="option_type_radio" name="correct" value="3" required>
                        <input type="text" id="text_question" name="option_array" required>
                        <br>
                        <input type="radio" id="option_type_radio" name="correct" value="4" required>
                        <input type="text" id="text_question" name="option_array" required>
                        <br><br>
                        
                    </div>
                `;
             }

            //  value=2
